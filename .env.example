# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.

# --- Airtable (control plane) ---
AIRTABLE_TOKEN=pat_xxx                 # Airtable personal access token (data.records:read/write on the base)
YT_AIRTABLE_BASE_ID=app4nnEYqZaKjBo1h  # the "YouTube Content Engine" base
# Optional overrides (defaults shown):
# YT_CHANNELS_TABLE=YT Channels
# YT_QUEUE_TABLE=YT Content Queue
# YT_CLIPS_TABLE=YT Clips

# --- YouTube Data API v3 (scrape layer) ---
YOUTUBE_API_KEY=AIza_xxx               # Google Cloud API key with "YouTube Data API v3" enabled
# YT_SEARCH_RESULTS=25                  # results pulled per keyword before ranking by views

# --- Gemini (generation) ---
GEMINI_API_KEY=AIza_xxx                # Google AI Studio key (reuse your existing one)
# GEMINI_MODEL=gemini-2.0-flash

# --- Behaviour ---
# YT_IDEAS_PER_CHANNEL=3               # default ideas per channel per run
# YT_CLIPS_PER_SOURCE=5                # default short-form clips per long-form source (repurpose phase)
# YT_DRY_RUN=true                      # log output instead of writing to Airtable (safe first run)
